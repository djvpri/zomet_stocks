# ===== AI Provider API Keys =====
CLAUDE_API_KEY=your_claude_api_key_here
QWEN_API_KEY=your_qwen_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# ===== AI Manager Settings =====
# Mode: single | fallback | consensus | cheapest
AI_MODE=fallback
# Provider utama (untuk mode single/fallback)
PRIMARY_PROVIDER=qwen
# Provider fallback (untuk mode fallback), pisahkan dengan koma
FALLBACK_PROVIDERS=deepseek,claude
# Provider untuk consensus, pisahkan dengan koma
CONSENSUS_PROVIDERS=qwen,deepseek,claude

# ===== Firebase FCM =====
FIREBASE_CREDENTIALS_PATH=firebase-credentials.json

# ===== Scheduler =====
# Frekuensi analisis dalam menit (saat jam bursa)
ANALYSIS_INTERVAL_MINUTES=60
# Timezone
TIMEZONE=Asia/Jakarta

# ===== Market Settings =====
# Jam buka bursa (WIB)
MARKET_OPEN_HOUR=9
MARKET_OPEN_MINUTE=0
# Jam tutup bursa (WIB)
MARKET_CLOSE_HOUR=15
MARKET_CLOSE_MINUTE=30
# Simbol IHSG di Yahoo Finance
IHSG_SYMBOL=^JKSE
